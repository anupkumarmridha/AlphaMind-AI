# AlphaMind AI Environment Configuration

# Ollama Configuration
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=kimi-k2.5:cloud

# Event Agent Models (uses OLLAMA_MODEL as default if not specified)
# EVENT_TRIAGE_MODEL: Fast model for news relevance filtering
# EVENT_EXTRACT_MODEL: Heavy model for deep sentiment extraction
# EVENT_FALLBACK_MODEL: Fallback model when primary models fail
EVENT_TRIAGE_MODEL=kimi-k2.5:cloud
EVENT_EXTRACT_MODEL=kimi-k2.5:cloud
EVENT_FALLBACK_MODEL=llama3.2:latest

# Database Configuration
DATABASE_URL=sqlite:///backend/alphamind.db
LEARNING_DATABASE_URL=sqlite:///backend/alphamind_learning.db
ALPHAMIND_DB_PATH=backend/alphamind.db

# OpenAI Configuration (optional, for future use)
# OPENAI_API_KEY=your_openai_api_key_here

# Logging Configuration
LOG_LEVEL=INFO
